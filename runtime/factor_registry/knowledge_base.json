[
  {
    "factor_name": "accruals",
    "category": "quality",
    "formula": "(net_profit_ttm - operating_cashflow_ttm) / total_assets",
    "description": "应计项目 = (净利润 - 经营现金流) / 总资产"
  },
  {
    "factor_name": "asset_turnover",
    "category": "quality",
    "formula": "revenue_ttm / average_total_assets",
    "description": "资产周转率 = 营业收入TTM / 平均总资产"
  },
  {
    "factor_name": "beta_1y",
    "category": "low_volatility",
    "formula": "cov(stock, hs300)/var(hs300) over 252d",
    "description": "市场Beta = 过去252日对沪深300回归斜率"
  },
  {
    "factor_name": "book_to_market",
    "category": "value",
    "formula": "net_assets / total_market_cap",
    "description": "账面市值比 = 净资产 / 总市值"
  },
  {
    "factor_name": "earnings_yield",
    "category": "value",
    "formula": "net_profit_ttm / total_market_cap",
    "description": "盈利收益率 = 净利润TTM / 总市值"
  },
  {
    "factor_name": "gross_margin",
    "category": "quality",
    "formula": "(revenue_ttm - total_cogs_ttm) / revenue_ttm",
    "description": "毛利率 = 毛利润 / 营业收入"
  },
  {
    "factor_name": "idiosyncratic_vol",
    "category": "low_volatility",
    "formula": "stddev(daily_returns, 60)",
    "description": "特质波动率 = 过去60日日收益率标准差"
  },
  {
    "factor_name": "mf_inflow_acceleration",
    "category": "moneyflow",
    "formula": "sum(net_mf_amount, 5) - sum(net_mf_amount, 20)",
    "description": "资金流入加速度 = 5日主力净流入 - 20日主力净流入"
  },
  {
    "factor_name": "mf_large_order_ratio",
    "category": "moneyflow",
    "formula": "sum(buy_elg_amount, 5) / (sum(buy_elg_amount, 5) + sum(sell_elg_amount, 5))",
    "description": "超大单净买入占比 = 过去5日超大单净买入 / (超大单净买入 + 超大单净卖出)"
  },
  {
    "factor_name": "mf_net_inflow_20d",
    "category": "moneyflow",
    "formula": "sum(net_mf_amount, 20) / total_market_cap",
    "description": "20日主力净流入强度 = 过去20日主力净流入额 / 总市值"
  },
  {
    "factor_name": "mf_net_inflow_5d",
    "category": "moneyflow",
    "formula": "sum(net_mf_amount, 5) / total_market_cap",
    "description": "5日主力净流入强度 = 过去5日主力净流入额 / 总市值"
  },
  {
    "factor_name": "mf_smart_money",
    "category": "moneyflow",
    "formula": "sum(buy_elg_amount - sell_elg_amount, 5) / sum(amount, 5)",
    "description": "聪明钱比率 = 过去5日超大单净流入 / 过去5日总成交额"
  },
  {
    "factor_name": "momentum_12_1",
    "category": "momentum",
    "formula": "return_252d_ex_last_21d",
    "description": "12-1月动量 = 过去252日收益率，跳过最近21日"
  },
  {
    "factor_name": "momentum_1m",
    "category": "momentum",
    "formula": "-return_21d",
    "description": "1月反转 = 过去21日收益率取负"
  },
  {
    "factor_name": "roe",
    "category": "quality",
    "formula": "net_profit_ttm / average_equity",
    "description": "净资产收益率 = 净利润TTM / 平均净资产"
  },
  {
    "factor_name": "sales_to_price",
    "category": "value",
    "formula": "revenue_ttm / total_market_cap",
    "description": "营收市值比 = 营业收入TTM / 总市值"
  }
]
